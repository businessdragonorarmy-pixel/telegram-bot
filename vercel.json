{
  "buildCommand": "pip install -r requirements.txt && python telegram_bot_project/manage.py collectstatic --noinput",
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "telegram_bot_project.settings"
  }
}
