{
  "buildCommand": "pip install -r requirements.txt && python manage.py migrate --noinput",
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
